<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/fragmentHome">

    <fragment
        android:id="@+id/fragmentHome"
        android:name="com.loosethread.moodsignals.fragments.FragmentHome"
        android:label="@string/home_fragment_label"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_HomeFragment_to_SignalsFragment"
            app:destination="@id/fragmentSignals" />
        <action
            android:id="@+id/action_HomeFragment_to_fragmentNotificationTimes"
            app:destination="@id/fragmentNotificationTimes" />
        <action
            android:id="@+id/action_HomeFragment_to_fragmentToday"
            app:destination="@id/fragmentToday" />
        <action
            android:id="@+id/action_HomeFragment_to_fragmentDaysLog"
            app:destination="@id/fragmentDaysLog" />
        <action
            android:id="@+id/action_HomeFragment_to_fragmentCategoriest"
            app:destination="@id/fragmentCategories" />
    </fragment>
    <fragment
        android:id="@+id/fragmentSignals"
        android:name="com.loosethread.moodsignals.fragments.FragmentSignals"
        android:label="@string/signals_fragment_label"
        tools:layout="@layout/fragment_signals">

        <action
            android:id="@+id/action_SignalsFragment_to_fragmentAddSignal"
            app:destination="@id/fragmentAddSignal" />
    </fragment>
    <fragment
        android:id="@+id/fragmentAddSignal"
        android:name="com.loosethread.moodsignals.fragments.FragmentAddSignal"
        android:label="Add Signal" />
    <fragment
        android:id="@+id/fragmentNotificationTimes"
        android:name="com.loosethread.moodsignals.FragmentNotificationTimes"
        android:label="Notification Times" >
        <action
            android:id="@+id/action_fragmentNotificationTimes_to_fragmentAddNotificationTime"
            app:destination="@id/fragmentAddNotificationTime" />
    </fragment>
    <fragment
        android:id="@+id/fragmentAddNotificationTime"
        android:name="com.loosethread.moodsignals.fragments.FragmentAddNotificationTime"
        android:label="Add Notification Time" />
    <fragment
        android:id="@+id/fragmentToday"
        android:name="com.loosethread.moodsignals.fragments.FragmentToday"
        android:label="Today" />
    <fragment
        android:id="@+id/fragmentDaysLog"
        android:name="com.loosethread.moodsignals.fragments.FragmentDaysLog"
        android:label="Log"
        tools:layout="@layout/fragment_days_log" />
    <fragment
        android:id="@+id/fragmentCategories"
        android:name="com.loosethread.moodsignals.FragmentCategories"
        android:label="Categories" />
</navigation>