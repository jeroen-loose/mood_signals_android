<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight">
    </style>

    <style name="list">
        <item name="android:background">@drawable/rounded_border</item>
        <item name="android:padding">2dp</item>
    </style>

    <style name="listtitle">
        <item name="android:radius">25dp</item>
    </style>

    <style name="listitem">
        <item name="android:padding">8dp</item>"
    </style>

    <style name="comment" parent="TextAppearance.AppCompat">
        <item name="android:padding">15dp</item>
        <item name="android:background">@drawable/rounded_border</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <style name="fragment">
        <item name="android:padding">15dp</item>
    </style>

    <style name="signal">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/rounded_background</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="signal.red">
        <item name="android:backgroundTint">@color/red</item>
    </style>

    <style name="signal.orange">
        <item name="android:backgroundTint">@color/orange</item>
    </style>

    <style name="signal.green">
        <item name="android:backgroundTint">@color/green</item>
    </style>

    <style name="spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:padding">8dp</item>
        <item name="android:backgroundTint">?android:textColorPrimary</item>
    </style>

</resources>